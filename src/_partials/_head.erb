<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link rel="icon" type="image/png" href="/favicon-48x48.png" sizes="48x48" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="shortcut icon" href="/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<meta name="apple-mobile-web-app-title" content="Trey's Dev Shed" />
<link rel="manifest" href="/site.webmanifest" />
<% resource_title=strip_html(strip_newlines(title)) %>
  <title>
    <% if resource_title !="Index" %>
      <%= resource_title %> | <%= metadata.title %>
          <% else %>
            <%= metadata.title %>
              <% end %>
  </title>

  <meta name="description" content="<%= metadata.description %>" />

  <link rel="stylesheet" href="<%= asset_path :css %>" />
  <script src="<%= asset_path :js %>" defer></script>
  <%= live_reload_dev_js %>
